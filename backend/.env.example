# Server
# Note: macOS uses port 5000 for AirPlay Receiver; 5001 avoids the clash.
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/online_judge

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Code execution
USE_DOCKER=false
EXECUTION_TIMEOUT_MS=5000
COMPILE_TIMEOUT_MS=20000

# Docker sandbox (used when USE_DOCKER=true). Build the image first:
#   docker build -t online-judge-executor backend/docker
DOCKER_IMAGE=online-judge-executor
DOCKER_MEMORY=256m
DOCKER_CPUS=1.0
DOCKER_PIDS_LIMIT=128
